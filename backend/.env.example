# Copy to .env for local development. NEVER commit .env.
SPORTSLOT_ENVIRONMENT=development
SPORTSLOT_GCP_PROJECT=sport-slot-dev
SPORTSLOT_BASE_DOMAIN=sportbook.chandraailabs.com
SPORTSLOT_ADMIN_HOST=admin.sportbook.chandraailabs.com
SPORTSLOT_DEV_TENANT_SLUG=demo
SPORTSLOT_LOG_LEVEL=INFO
SPORTSLOT_RATE_LIMIT=30/minute
# Web API key (public client identifier, still not committed)
# Firebase Console → Project settings → General → Web API Key
SPORTSLOT_WEB_API_KEY=replace-me
SPORTSLOT_REDIS_HOST=localhost
SPORTSLOT_REDIS_PORT=6379
# SPORTSLOT_REDIS_AUTH=   (unset locally; Secret Manager in cloud)
