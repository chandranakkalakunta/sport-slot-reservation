rules_version = '2';

// SportSlotReservation - Firestore Security Rules
// Phase 1.3.3 baseline: DENY ALL access
// Future phases will add tenant-isolation rules per ADR-0004

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — no client can read or write anything
    // This is the secure baseline.
    // Real rules added in Phase 2 with tenant_id checks.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
