rules_version = '2';
// ADR-0008 Decision 1: PERMANENTLY DENY-ALL.
// All data access flows through the backend (Admin SDK, which
// bypasses these rules). These rules exist to guarantee that no
// client SDK or leaked web config can ever touch Firestore
// directly. Do NOT add allow statements — that requires a
// superseding ADR.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
