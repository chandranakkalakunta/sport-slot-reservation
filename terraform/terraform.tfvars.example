# SportSlotReservation — Terraform Variables (Example)
#
# Copy this file to terraform.tfvars and fill in actual values.
# terraform.tfvars is gitignored (contains environment-specific values).

project_id         = "sport-slot-dev"
project_number     = "707808711911"
organization_id    = "833112493322"
billing_account_id = "014A8C-586310-DE4575"
region             = "asia-south1"
zone               = "asia-south1-a"
environment        = "dev"
github_repository  = "chandranakkalakunta/sport-slot-reservation"

# ADR-0040 (PR-2): SMS alert notification channel number, E.164 format.
# Coordinator-supplied; never a real number in this example file.
alert_sms_number = "+91XXXXXXXXXX"
