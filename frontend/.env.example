# Firebase web app config — PUBLIC client identifiers (not secrets).
# Console → Project settings → Your apps → Web app → SDK config.
# Copy this file to .env.local and fill values; .env.local is gitignored.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sport-slot-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sport-slot-dev
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Dev-only tenant fallback (no subdomain on localhost). Mirrors the
# backend dev override; ignored in production builds.
VITE_DEV_TENANT_SLUG=demo
# Default tenant for non-subdomain hosts (e.g. the *.web.app DEV
# surface, which has no tenant subdomain). Ignored when a real
# {slug}.sportbook subdomain is present (Phase 7 custom domain).
VITE_DEFAULT_TENANT_SLUG=demo
